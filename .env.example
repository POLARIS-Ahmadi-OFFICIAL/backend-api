APP_NAME=POLARIS API
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081

# Set AUTH_DISABLED=false in production
AUTH_DISABLED=true
SUPABASE_URL=
SUPABASE_JWT_SECRET=

DATABASE_URL=sqlite:///./data/polaris.db
POLARIS_DB_PATH=./data/polaris.db

LLM_PROVIDER=qwen
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Gemini free tier: Hypothesis uses several sequential LLM calls. Space requests to avoid 429:
GEMINI_MIN_INTERVAL_SEC=6
GEMINI_MAX_RETRIES=3
# Hypothesis speed (defaults favor fewer API round-trips):
# HYPOTHESIS_FAST_MODE=1          # combined socratic+TOT after clarify (default on)
# HYPOTHESIS_SKIP_READINESS_CHECK=1  # skip extra LLM per next-step pick (default on)
# HYPOTHESIS_SKIP_SOCRATIC_ANSWERS=1 # skip answer step; use with FAST_MODE or alone
# HYPOTHESIS_SKIP_ANALYSIS_ON_GENERATE=1  # hypothesis only, no analysis rubric LLM
# HYPOTHESIS_CONTEXT_MAX_CHARS=4500
LITERATURE_MCP_ENDPOINT=http://127.0.0.1:8000/mcp
WATCHER_PORT=8765
